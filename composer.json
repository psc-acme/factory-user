{
    "name": "psc-acme/factory-user",
    "description": "Package factory-user for psc-acme organization",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\FactoryUser\\": "src/"
        }
    },
    "require": {
        "php": ">=8.2",
        "symfony/console": "^7.0",
        "symfony/event-dispatcher": "^7.0",
        "doctrine/dbal": "^4.0"
    },
    "require-dev": {
        "webforge/object-asserter": "^2.0.0"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}